# ============================================================================
# Variaveis de ambiente — SDR WhatsApp GoldIncision
# NUNCA commitar este arquivo com valores reais
# Em producao, usar Docker secrets para valores sensiveis
# ============================================================================

# --- Banco de dados ---
DATABASE_URL=postgresql+asyncpg://sdr:SENHA_AQUI@postgres:5432/sdr
POSTGRES_PASSWORD=SENHA_AQUI

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- OpenAI (usar Docker secret em producao) ---
OPENAI_API_KEY=sk-COLOQUE_SUA_CHAVE_AQUI
OPENAI_MODEL_REASONING=gpt-4o
OPENAI_MODEL_CHEAP=gpt-4o-mini

# --- ChatMaster (usar Docker secret em producao) ---
CHATMASTER_TOKEN=TOKEN_CHATMASTER_AQUI
CHATMASTER_BASE_URL=https://api2.chatmasterveloz.com

# --- Handoff humano (API "Atualizar Ticket": queueId/userId=null/status=pending) ---
# Fila humana padrao (queueId) para onde transferir quando o destino logico
# do fluxo nao tiver mapeamento especifico. Obrigatorio para o handoff funcionar.
HANDOFF_QUEUE_ID_DEFAULT=78
# (opcional) mapa destino-logico -> queueId em JSON. Destinos: consultores,
# vendas, suporte, especialista, presencial, licenciamento, franquia.
HANDOFF_QUEUE_IDS_JSON={"consultores": 78, "presencial": 78, "licenciamento": 78, "franquia": 78, "suporte": 78, "especialista": 78}

# --- Gate de fila da IA ---
# O agente SO atende quando o ticket esta nesta fila (queueId). Mensagens de outra
# fila (ex.: 78 = atendimento humano) sao ignoradas — humano atende no mesmo numero.
# Deixar vazio desativa o gate (processa todas as filas).
AI_QUEUE_ID=77

# --- Numeros de teste (#reset) — CSV; semeia a tabela numero_teste no startup ---
RESET_TEST_NUMBERS=5511967296849,5511941410998,555195953520

# --- Admin API (usar Docker secret em producao) ---
ADMIN_TOKEN=TOKEN_ADMIN_SEGURO_AQUI

# --- Webhook (opcional — defesa em profundidade) ---
# Deixar vazio para desabilitar validacao do header X-Webhook-Token
WEBHOOK_TOKEN=

# --- Debounce ---
DEBOUNCE_SECONDS=8

# --- Controle de turnos (Pilar 7 — G1-G6) ---
# Teto de turnos consecutivos no MESMO no do mapa-mestre antes do nudge
# (reforco da pergunta pendente; NAO e handoff). Reseta ao mudar de etapa.
MAX_TURNOS_NO_NO=6
# Teto de turnos na sessao inteira antes de escalar para handoff cordial.
MAX_TURNOS_SESSAO=25
# Limiar de turnos predominantemente de duvida/pergunta antes de escalar.
MAX_TURNOS_DUVIDAS=12
# Janela (horas) para retomada cordial de sessao inativa (sem reiniciar jornada).
REENGAJAMENTO_HORAS=24
# Janela (horas) apos a qual a sessao vira nova, preservando perfil do Contato.
EXPIRA_SESSAO_HORAS=72
# TTL do lock de exclusividade por ticket, em ms (elevado de 30s para 90s
# com base no pior caso observado de duracao de turno).
LOCK_TTL_MS=90000

# --- Pacing de envio (WhatsApp Cloud API via ChatMaster) ---
# Intervalo minimo entre envios consecutivos (anti-rajada / rate limit da Meta), em ms.
WHATSAPP_MIN_INTERVAL_MS=1000
# Teto de mensagens por turno do bot: acima disso, consolida o restante num
# unico bloco curto com convite (nunca despeja todos os blocos).
MAX_MSGS_PER_TURN=4
# Pausa entre blocos consecutivos (segundos).
INTER_BLOCK_DELAY_SECONDS=1.0

# --- Concisao das respostas geradas ---
# Teto de tokens da geracao de raciocinio (respostas objetivas e resumidas).
REASONING_MAX_TOKENS=280

# --- Portao de Fidelidade (Pilar 7) ---
# Teto (hard) do FidelityGate.verificar(); timeout/erro/indisponibilidade conta
# SEMPRE como fiel=False (fail-closed). Alvo interno de latencia real: ~2s.
VERIFY_TIMEOUT_SECONDS=3

# --- Interpretacao Agentica / Slot-Filling (Pilar 8) ---
# Limiar minimo de confianca para aceitar um slot extraido pelo SlotExtractor
# (fallback agentico); abaixo disso reformula, nunca adivinha o valor.
SLOT_CONFIDENCE_THRESHOLD=0.6

# --- Numero da Nidia (caminho 5 — paciente modelo) ---
NIDIA_PHONE=5511XXXXXXXXX

# --- Swarm/Docker networks ---
# Nome real da overlay do n8n (confirmar com: docker network ls)
N8N_NETWORK=n8n-net
# Nome real da rede do Traefik (confirmar com: docker network ls)
TRAEFIK_NETWORK=traefik-public
# Host publico para labels Traefik
SDR_HOST=sdr.todo-tips.com
